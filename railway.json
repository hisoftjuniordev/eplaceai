{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"python -m uvicorn src.api:app --host 0.0.0.0 --port $PORT\"",
    "healthcheckPath": "/api/stats",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
