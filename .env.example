# PostgreSQL — use managed DB URL from Railway/Render/etc.
DATABASE_URL=postgresql://postgres:password@localhost:5432/si_payroll
DB_PASSWORD=password

# Connection pool
DB_MIN_POOL=2
DB_MAX_POOL=10

# OpenRouter API key — free models at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Groq API key — fast free inference at https://console.groq.com/keys
GROQ_API_KEY=
